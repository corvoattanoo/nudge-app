// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            Int      @id @default(autoincrement())
  email         String   @unique @db.VarChar(255)
  name          String?
  password_hash String   @db.Text
  username      String   @unique @db.VarChar(50)
  avatarUrl     String?  @db.Text
  createdAt     DateTime @default(now()) @db.Timestamptz
  updatedAt     DateTime @updatedAt @db.Timestamptz

  groupsCreated Group[]
  groupMemberships GroupMembers[]
  eventShares event_shares[]
  votes Vote[]
}

model Group {
  id        Int    @id @default(autoincrement())
  groupName String

  created_by_id Int
  created_by    User @relation(fields: [created_by_id], references: [id])

  createdAt DateTime @default(now()) @db.Timestamptz
  groupMembers GroupMembers[]
  eventShares event_shares[]
}

model GroupMembers {
  id       Int @id @unique @default(autoincrement())
  group_id Int

  user_id Int
  role    GroupRole @default(MEMBER)

  group Group @relation(fields: [group_id], references: [id])
  user  User  @relation(fields: [user_id], references: [id]) 
  //group modeldeki user_id ile referansdaki user id islesiyor 
}

enum GroupRole {
  ADMIN
  MEMBER
}

model Event {
  id       Int @id @unique @default(autoincrement())
  title String @db.VarChar(255)
  description String? @db.Text
  location_name String  @db.VarChar(255)
  lat Float
  lng Float
  starts_at DateTime @default(now()) @db.Timestamptz
  ends_at DateTime? @db.Timestamptz
  price        Decimal   @db.Decimal(10, 2)
  currency String @default("PLN") @db.VarChar(3)
  category String @db.VarChar(50)
  imageUrl String @db.Text
  sourceUrl String @db.Text
  createdAt DateTime @default(now()) @db.Timestamptz
  eventShares event_shares[]
}

model event_shares {
  id Int  @id @unique @default(autoincrement())
  event_id Int  
  group_id Int 
  user_id  Int 
  status Status @default(PENDING)
  shared_at DateTime @default(now()) @db.Timestamptz()

  event Event @relation(fields: [event_id], references: [id])
  group Group @relation(fields: [group_id], references: [id])
  sharedBy User @relation(fields: [user_id],references: [id])

  votes Vote[]
}

enum Status{
  PENDING 
  APPROVED
  REJECTED
}

// group Group @relation(fields: [group_id], references: [id])
  //group modeldeki user_id ile referansdaki user id islesiyor 

model Vote {
  id Int @id @default(autoincrement())
  event_share_id Int
  user_id Int
  status voteDecision @default(PENDING)

  eventShare event_shares @relation(fields: [event_share_id],references: [id])
  user User @relation(fields: [user_id], references: [id])
  @@unique([event_share_id, user_id])

  created_at DateTime @default(now()) @db.Timestamptz()
}

enum voteDecision{
  APPROVE
  REJECT
  PENDING
}
